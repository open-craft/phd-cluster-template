{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PHD Cluster Template Configuration",
  "description": "Configuration schema for generating Open edX Kubernetes cluster infrastructure using Terraform",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for validation",
      "example": "./cookiecutter.schema.json"
    },
    "cluster_name": {
      "type": "string",
      "description": "Human-readable name for the Kubernetes cluster",
      "minLength": 1,
      "maxLength": 32,
      "pattern": "^[a-zA-Z0-9\\s\\-_]+$",
      "examples": [
        "PHD Production Cluster",
        "Open edX Staging Environment",
        "Development Test Cluster"
      ]
    },
    "cluster_slug": {
      "type": "string",
      "description": "URL-safe identifier for the cluster (auto-generated from cluster_name)",
      "pattern": "^[a-z][a-z0-9\\-_]+$|^\\{\\{.*\\}\\}$",
      "examples": [
        "phd-production-cluster",
        "openedx-staging-environment",
        "development-test-cluster",
        "{{ cookiecutter.cluster_name.lower().replace(' ', '-') }}"
      ]
    },
    "environment": {
      "type": "string",
      "enum": ["production", "staging", "development"],
      "description": "Deployment environment type",
      "examples": ["production"]
    },
    "short_description": {
      "type": "string",
      "description": "Brief description of the cluster's purpose",
      "minLength": 10,
      "maxLength": 100,
      "examples": [
        "Kubernetes cluster to host Open edX instances",
        "Production environment for online learning platform",
        "Development and testing environment"
      ]
    },
    "cluster_vpc_ip_range": {
      "type": "string",
      "description": "CIDR block for the cluster's VPC network",
      "pattern": "^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)/([0-9]|[1-2][0-9]|3[0-2])$",
      "examples": ["10.12.0.0/24", "10.0.0.0/16", "172.16.0.0/20"]
    },
    "cloud_provider": {
      "type": "string",
      "enum": ["aws", "digitalocean"],
      "description": "Cloud provider for infrastructure deployment",
      "examples": ["aws"]
    },
    "region": {
      "type": "string",
      "anyOf": [
        {
          "if": {
            "properties": {
              "cloud_provider": { "const": "aws" }
            }
          },
          "then": {
            "enum": [
              "us-east-1",
              "us-east-2",
              "us-west-1",
              "us-west-2",
              "ca-central-1",
              "ca-west-1",
              "eu-central-1",
              "eu-central-2",
              "eu-west-1",
              "eu-west-2",
              "eu-west-3",
              "eu-north-1",
              "eu-south-1",
              "eu-south-2",
              "ap-south-1",
              "ap-south-2",
              "ap-southeast-1",
              "ap-southeast-2",
              "ap-southeast-3",
              "ap-southeast-4",
              "ap-southeast-5",
              "ap-southeast-7",
              "ap-northeast-1",
              "ap-northeast-2",
              "ap-northeast-3",
              "ap-east-1",
              "sa-east-1",
              "me-south-1",
              "me-central-1",
              "il-central-1",
              "af-south-1",
              "cn-north-1",
              "cn-northwest-1",
              "us-gov-east-1",
              "us-gov-west-1",
              "us-isob-east-1",
              "us-iso-east-1",
              "us-iso-west-1"
            ],
            "description": "AWS region identifier",
            "examples": [
              "us-east-1",
              "us-west-2",
              "eu-west-1",
              "ap-southeast-1"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "cloud_provider": { "const": "digitalocean" }
            }
          },
          "then": {
            "enum": [
              "ams3",
              "blr1",
              "fra1",
              "lon1",
              "nyc3",
              "sfo2",
              "sfo3",
              "sgp1",
              "syd1",
              "tor1"
            ],
            "description": "DigitalOcean region identifier",
            "examples": ["nyc3", "sfo3", "fra1", "sgp1"]
          }
        }
      ]
    },
    "mysql_version": {
      "type": "string",
      "description": "MySQL database version (supported by the cloud provider)",
      "pattern": "^[0-9]+(\\.[0-9]+)*$",
      "examples": ["8", "8.0"]
    },
    "mysql_instance_size": {
      "type": "string",
      "oneOf": [
        {
          "if": {
            "properties": {
              "cloud_provider": { "const": "aws" }
            }
          },
          "then": {
            "description": "AWS RDS MySQL instance type",
            "enum": [
              "db.t2.micro",
              "db.t2.small",
              "db.t2.medium",
              "db.t2.large",
              "db.t2.xlarge",
              "db.t2.2xlarge",
              "db.t3.micro",
              "db.t3.small",
              "db.t3.medium",
              "db.t3.large",
              "db.t3.xlarge",
              "db.t3.2xlarge",
              "db.t4g.micro",
              "db.t4g.small",
              "db.t4g.medium",
              "db.t4g.large",
              "db.t4g.xlarge",
              "db.t4g.2xlarge",
              "db.r5.large",
              "db.r5.xlarge",
              "db.r5.2xlarge",
              "db.r5.4xlarge",
              "db.r5.8xlarge",
              "db.r5.12xlarge",
              "db.r5.16xlarge",
              "db.r5.24xlarge",
              "db.r6g.large",
              "db.r6g.xlarge",
              "db.r6g.2xlarge",
              "db.r6g.4xlarge",
              "db.r6g.8xlarge",
              "db.r6g.12xlarge",
              "db.r6g.16xlarge"
            ],
            "examples": ["db.t3.micro", "db.t3.small", "db.r5.large"]
          }
        },
        {
          "if": {
            "properties": {
              "cloud_provider": { "const": "digitalocean" }
            }
          },
          "then": {
            "description": "DigitalOcean MySQL database instance size",
            "enum": [
              "db-s-1vcpu-1gb",
              "db-s-1vcpu-2gb",
              "db-s-2vcpu-4gb",
              "db-s-4vcpu-8gb",
              "db-s-6vcpu-16gb",
              "db-s-8vcpu-32gb",
              "db-m-1vcpu-4gb",
              "db-m-2vcpu-8gb",
              "db-m-4vcpu-16gb",
              "db-m-6vcpu-24gb",
              "db-m-8vcpu-32gb",
              "db-m-12vcpu-48gb",
              "db-m-16vcpu-64gb"
            ],
            "examples": ["db-s-1vcpu-1gb", "db-s-1vcpu-2gb", "db-s-2vcpu-4gb"]
          }
        }
      ]
    },
    "mysql_cluster_instances": {
      "type": "integer",
      "description": "Number of MySQL cluster instances",
      "minimum": 1,
      "maximum": 10,
      "examples": [1, 3, 5]
    },
    "mongodb_version": {
      "type": "string",
      "description": "MongoDB database version (supported by the cloud provider)",
      "pattern": "^[0-9]+(\\.[0-9]+)*$",
      "examples": ["7", "7.0", "7.0.4"]
    },
    "mongodb_instance_size": {
      "type": "string",
      "oneOf": [
        {
          "if": {
            "properties": {
              "cloud_provider": { "const": "aws" }
            }
          },
          "then": {
            "description": "AWS DocumentDB MongoDB instance type",
            "enum": [
              "db.t3.medium",
              "db.t3.large",
              "db.t3.xlarge",
              "db.t3.2xlarge",
              "db.t4g.medium",
              "db.t4g.large",
              "db.t4g.xlarge",
              "db.t4g.2xlarge",
              "db.r5.large",
              "db.r5.xlarge",
              "db.r5.2xlarge",
              "db.r5.4xlarge",
              "db.r5.8xlarge",
              "db.r5.12xlarge",
              "db.r5.16xlarge",
              "db.r5.24xlarge",
              "db.r6g.large",
              "db.r6g.xlarge",
              "db.r6g.2xlarge",
              "db.r6g.4xlarge",
              "db.r6g.8xlarge",
              "db.r6g.12xlarge",
              "db.r6g.16xlarge"
            ],
            "examples": ["db.t3.medium", "db.r5.large", "db.r5.xlarge"]
          }
        },
        {
          "if": {
            "properties": {
              "cloud_provider": { "const": "digitalocean" }
            }
          },
          "then": {
            "description": "DigitalOcean MongoDB database instance size",
            "enum": [
              "db-s-1vcpu-1gb",
              "db-s-1vcpu-2gb",
              "db-s-2vcpu-4gb",
              "db-s-4vcpu-8gb",
              "db-s-6vcpu-16gb",
              "db-s-8vcpu-32gb",
              "db-m-1vcpu-4gb",
              "db-m-2vcpu-8gb",
              "db-m-4vcpu-16gb",
              "db-m-6vcpu-24gb",
              "db-m-8vcpu-32gb",
              "db-m-12vcpu-48gb",
              "db-m-16vcpu-64gb"
            ],
            "examples": ["db-s-1vcpu-1gb", "db-s-1vcpu-2gb", "db-s-2vcpu-4gb"]
          }
        }
      ]
    },
    "mongodb_cluster_instances": {
      "type": "integer",
      "description": "Number of MongoDB cluster instances",
      "minimum": 1,
      "maximum": 10,
      "examples": [1, 3, 5]
    },
    "harmony_version": {
      "type": "string",
      "description": "Open edX Harmony Terraform module version (git commit hash or tag)",
      "pattern": "^[a-f0-9]{40}$|^[a-zA-Z0-9\\-_\\.]+$",
      "examples": [
        "bfdcca60d62801acbf61e77f49de25889647b5ef",
        "main",
        "v1.0.0"
      ]
    },
    "letsencrypt_email": {
      "type": "string",
      "description": "Email address for Let's Encrypt SSL certificate notifications",
      "format": "email",
      "examples": [
        "admin@example.com",
        "dev@opencraft.com",
        "ssl@yourdomain.org"
      ]
    },
    "picasso_version": {
      "type": "string",
      "description": "Picasso build system version (git branch, tag, or commit)",
      "examples": ["main", "develop", "v2.1.0", "abc123def456"]
    },
    "buildkit_parallelism": {
      "type": "integer",
      "description": "Maximum number of parallel build layers for Docker BuildKit",
      "minimum": 1,
      "maximum": 16,
      "default": 3,
      "examples": [1, 3, 5, 8]
    }
  },
  "required": [
    "$schema",
    "cluster_name",
    "cluster_slug",
    "environment",
    "region",
    "short_description",
    "cluster_vpc_ip_range",
    "cloud_provider",
    "mysql_version",
    "mysql_instance_size",
    "mysql_cluster_instances",
    "mongodb_version",
    "mongodb_instance_size",
    "mongodb_cluster_instances",
    "harmony_version",
    "letsencrypt_email",
    "picasso_version",
    "buildkit_parallelism"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "cluster_name": "PHD Production Cluster",
      "cluster_slug": "{{ cookiecutter.cluster_name.lower().replace(' ', '-') }}",
      "environment": "production",
      "region": "us-east-1",
      "short_description": "Kubernetes cluster to host Open edX instances",
      "cluster_vpc_ip_range": "10.12.0.0/24",
      "cloud_provider": "aws",
      "mysql_version": "8",
      "mysql_instance_size": "db.t3.micro",
      "mysql_cluster_instances": 1,
      "mongodb_version": "7",
      "mongodb_instance_size": "db.t3.medium",
      "mongodb_cluster_instances": 3,
      "harmony_version": "bfdcca60d62801acbf61e77f49de25889647b5ef",
      "letsencrypt_email": "admin@example.com",
      "picasso_version": "main",
      "buildkit_parallelism": 3,
      "$schema": "./cookiecutter.schema.json"
    }
  ]
}
